# SkillBridge environment examples
#
# Copy the backend section into backend/.env.
# Copy the frontend section into frontend/.env.

# Backend
PORT=5000
DATABASE_URL="mysql://skillbridge_user:skillbridge_password@localhost:3306/skillbridge"
SHADOW_DATABASE_URL="mysql://root:root@localhost:3306/skillbridge_shadow"
MONGO_URI="mongodb://localhost:27017/skillbridge"
JWT_SECRET="change_this_secret_in_production"
JWT_EXPIRES_IN="1h"
BCRYPT_SALT_ROUNDS=12
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"

# Frontend
VITE_API_URL=http://localhost:5000/api
