generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum GroupRole {
  OWNER
  MEMBER
}

enum BookingStatus {
  REGISTERED
  CANCELLED
}

model User {
  id               Int           @id @default(autoincrement())
  firstname        String        @db.VarChar(100)
  lastname         String        @db.VarChar(100)
  email            String        @unique @db.VarChar(255)
  password         String        @db.VarChar(255)
  passwordResetToken   String?   @db.VarChar(255)
  passwordResetExpires DateTime?
  role             UserRole      @default(USER)
  status           UserStatus    @default(ACTIVE)
  profile          Profile?
  skills           UserSkill[]
  ownedGroups      Group[]       @relation("GroupOwner")
  groupMemberships GroupMember[]
  createdSessions  Session[]     @relation("SessionCreator")
  bookings         Booking[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([passwordResetToken])
  @@map("users")
}

model Profile {
  id           Int      @id @default(autoincrement())
  bio          String?  @db.Text
  avatarUrl    String?  @db.VarChar(500)
  level        Level?
  availability String?  @db.VarChar(255)
  location     String?  @db.VarChar(255)
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("profiles")
}

model Skill {
  id        Int         @id @default(autoincrement())
  name      String      @unique @db.VarChar(100)
  category  String      @db.VarChar(100)
  users     UserSkill[]
  groups    Group[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("skills")
}

model UserSkill {
  id        Int      @id @default(autoincrement())
  userId    Int
  skillId   Int
  level     Level    @default(BEGINNER)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, skillId])
  @@map("user_skills")
}

model Group {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(150)
  description String?       @db.Text
  level       Level
  ownerId     Int
  skillId     Int
  owner       User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  skill       Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  members     GroupMember[]
  sessions    Session[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("groups")
}

model GroupMember {
  id       Int       @id @default(autoincrement())
  userId   Int
  groupId  Int
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("group_members")
}

model Session {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(150)
  description     String?   @db.Text
  startDate       DateTime
  duration        Int
  maxParticipants Int?
  groupId         Int
  createdBy       Int
  group           Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator         User      @relation("SessionCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  bookings        Booking[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("sessions")
}

model Booking {
  id        Int           @id @default(autoincrement())
  userId    Int
  sessionId Int
  status    BookingStatus @default(REGISTERED)
  bookedAt  DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("bookings")
}
